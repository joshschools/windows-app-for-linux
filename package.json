{
  "name": "windows-app-for-linux",
  "productName": "Windows App for Linux",
  "version": "1.0.2",
  "description": "Unofficial client for Windows App - Access Azure Virtual Desktops on Linux via Windows App web access",
  "main": "src/main.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "start:x11": "env -u ELECTRON_RUN_AS_NODE ELECTRON_OZONE_PLATFORM=x11 WINDOWS_APP_DISABLE_GPU=1 electron .",
    "test": "node --test",
    "build": "electron-builder",
    "build:appimage": "electron-builder --linux AppImage",
    "build:snap": "./scripts/build-snap.sh",
    "build:flatpak": "flatpak-builder build/flatpak-build src/windows-app-for-linux.desktop.yml --force-clean",
    "install:flatpak": "flatpak-builder --user --install --force-clean build/flatpak-build src/windows-app-for-linux.desktop.yml",
    "clean": "rm -rf build/ .snapcraft/ *.snap",
    "clean:snap": "rm -rf build/snap/",
    "clean:flatpak": "rm -rf build/flatpak-build/"
  },
  "keywords": [
    "electron",
    "windows-cloud",
    "remote-desktop"
  ],
  "author": "joshschools",
  "license": "MIT",
  "build": {
    "appId": "io.github.joshschools.WindowsAppForLinux",
    "productName": "Windows App for Linux",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "build/appimage"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Network",
      "icon": "src/windows-app-for-linux.desktop.512x512.png"
    }
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.15.2"
  }
}

